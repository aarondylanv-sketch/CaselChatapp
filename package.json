{
  "name": "casel",
  "version": "1.0.0",
  "description": "Casel - Private Group Chat",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:exe": "electron-builder --win"
  },
  "author": "Casel",
  "license": "SEE LICENSE IN license.txt",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.casel.chat",
    "productName": "Casel",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "icon.png",
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Casel"
    },
    "files": [
      "**/*",
      "!node_modules",
      "!dist"
    ]
  }
}